{
  "manifest_version": 3,
  "name": "Quick Autofill",
  "version": "1.0",
  "description": "Save profile info and autofill web forms instantly",

  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],

  "icons": {
    "16": "icons/logo16.png",
    "32": "icons/logo32.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Autofill",
    "default_icon": {
      "16": "icons/logo16.png",
      "32": "icons/logo32.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
